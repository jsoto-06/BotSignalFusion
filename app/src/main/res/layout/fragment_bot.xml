<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_cyberpunk_gradient"
    android:padding="20dp">

    <TextView
        android:id="@+id/tvHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="FUTURES TERMINAL"
        android:textColor="@color/text_grey"
        android:textSize="12sp"
        android:letterSpacing="0.2"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvTitle"
        android:layout_below="@id/tvHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SignalFusion Pro"
        android:textColor="@color/white"
        android:textSize="26sp"
        android:fontFamily="sans-serif-black" />

    <com.google.android.material.chip.Chip
        android:id="@+id/chipStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:text="● ONLINE"
        android:textColor="@color/neon_green"
        app:chipBackgroundColor="@color/cyber_card_bg"
        app:chipStrokeColor="@color/neon_green"
        app:chipStrokeWidth="1dp" />

    <TextView
        android:id="@+id/tvSaludBot"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/chipStatus"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="4dp"
        android:text="⚪ Calibrando..."
        android:textSize="11sp"
        android:textStyle="bold"
        android:textColor="@color/text_grey"/>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardSwitch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/tvTitle"
        android:layout_marginTop="20dp"
        app:cardBackgroundColor="@color/cyber_card_bg"
        app:cardCornerRadius="20dp"
        app:strokeColor="#22FFFFFF"
        app:strokeWidth="1dp">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="15dp">
            <ImageView
                android:id="@+id/iconPower"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_lock_power_off"
                app:tint="@color/white"
                android:layout_centerVertical="true"/>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_toEndOf="@id/iconPower"
                android:layout_marginStart="12dp"
                android:layout_centerVertical="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MOTOR AUTOMÁTICO"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/txtEstadoSimple"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Escaneando..."
                    android:textColor="@color/neon_green"
                    android:textSize="11sp" />
            </LinearLayout>

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchBotActive"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text=""
                app:showText="false"
                app:thumbTint="@color/white"
                app:trackTint="@color/neon_green" />

        </RelativeLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardMain"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/cardSwitch"
        android:layout_marginTop="15dp"
        app:cardBackgroundColor="@color/cyber_card_bg"
        app:cardCornerRadius="24dp"
        app:strokeColor="#33FFFFFF"
        app:strokeWidth="1dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CAPITAL TOTAL (USDT)"
                android:textColor="@color/text_grey"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tvTotalBalance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-light"
                android:text="$1,000.00"
                android:textColor="@color/neon_green"
                android:textSize="42sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="5dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="WIN RATE (24H)"
                        android:textColor="@color/text_grey"
                        android:textSize="10sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/tvWinRate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--%"
                        android:textColor="@color/neon_gold"
                        android:textSize="18sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="end">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PnL DIARIO"
                        android:textColor="@color/text_grey"
                        android:textSize="10sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/tvDailyPnL"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$0.00"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#22FFFFFF"
                android:layout_marginVertical="10dp" />

            <TextView
                android:id="@+id/tvLivePrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BTC: $00,000.00"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:alpha="0.8" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:id="@+id/layoutIndicators"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/cardMain"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            app:cardBackgroundColor="@color/cyber_card_bg"
            app:cardCornerRadius="12dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RSI"
                    android:textColor="@color/text_grey"
                    android:textSize="9sp" />
                <TextView
                    android:id="@+id/txtRSI"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="@color/neon_gold"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.2"
            android:layout_marginEnd="6dp"
            app:cardBackgroundColor="@color/cyber_card_bg"
            app:cardCornerRadius="12dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TENDENCIA"
                    android:textColor="@color/text_grey"
                    android:textSize="9sp" />
                <TextView
                    android:id="@+id/txtTendencia"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="@color/neon_green"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            app:cardBackgroundColor="@color/cyber_card_bg"
            app:cardCornerRadius="12dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ATR"
                    android:textColor="@color/text_grey"
                    android:textSize="9sp" />
                <TextView
                    android:id="@+id/txtVolatilidad"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="@color/neon_cyan"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardActiveTrade"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/layoutIndicators"
        android:layout_marginTop="16dp"
        android:visibility="gone"
        app:cardBackgroundColor="#1A1A24"
        app:cardCornerRadius="16dp"
        app:strokeColor="@color/neon_blue"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_menu_compass"
                    app:tint="@color/neon_blue"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="POSICIÓN ACTIVA"
                    android:textColor="@color/neon_blue"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:id="@+id/tvTradeTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textColor="@color/text_grey"
                    android:textSize="12sp"
                    android:fontFamily="monospace"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tvTradeSymbol"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BTCUSDT"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/tvTradeType"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LONG ↗"
                        android:textColor="@color/neon_green"
                        android:textSize="14sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PnL Actual"
                        android:textColor="@color/text_grey"
                        android:textSize="11sp"/>
                    <TextView
                        android:id="@+id/tvTradePnL"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+0.00%"
                        android:textColor="@color/white"
                        android:textSize="24sp"
                        android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>

            <Button
                android:id="@+id/btnCloseTrade"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="CERRAR POSICIÓN"
                android:backgroundTint="@color/neon_red"
                android:textColor="@color/white"
                android:textStyle="bold"
                app:cornerRadius="8dp"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:id="@+id/layoutBottomLog"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/cardActiveTrade"
        android:layout_marginTop="15dp"
        android:background="#1A000000"
        android:padding="12dp">
        <TextView
            android:id="@+id/txtEstadoDetalle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="> Esperando señales..."
            android:textColor="@color/neon_green"
            android:fontFamily="monospace"
            android:textSize="12sp" />
    </LinearLayout>



</RelativeLayout>